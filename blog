<!DOCTYPE html>
<html>
<head>
    <title>My Travel Blog</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
        }

        /* Navigation Bar */
        nav {
            background-color: #2c3e50;
            padding: 15px;
            text-align: center;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin: 0 20px;
            font-size: 18px;
        }

        nav a:hover {
            color: #f39c12;
        }

        /* Header */
        header {
            text-align: center;
            padding: 30px;
            background: #3498db;
            color: white;
        }

        /* Travel Cards */
        .container {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            padding: 20px;
        }

        .card {
            background: white;
            width: 300px;
            margin: 15px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            overflow: hidden;
            transition: 0.3s;
        }

        .card:hover {
            transform: scale(1.05);
        }

        .card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .card-content {
            padding: 15px;
        }

        .card-content h3 {
            margin: 0;
        }

        .btn {
            display: inline-block;
            padding: 10px 15px;
            background: #3498db;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            margin-top: 10px;
        }

        .btn:hover {
            background: #2980b9;
        }

        footer {
            text-align: center;
            padding: 15px;
            background: #2c3e50;
            color: white;
            margin-top: 20px;
        }
    </style>
</head>
<body>

    <!-- Navigation -->
    <nav>
        <a href="#">Home</a>
        <a href="#">Destinations</a>
        <a href="#">About</a>
        <a href="#">Contact</a>
    </nav>

    <!-- Header -->
    <header>
        <h1>My Travel Blog</h1>
        <p>Explore Beautiful Places Around the World 🌎</p>
    </header>

    <!-- Travel Locations -->
    <div class="container">

        <!-- Location 1 -->
        <div class="card">
            <img src="https://images.hindustantimes.com/rf/image_size_960x540/HT/p2/2018/08/16/Pictures/_dbca9ffa-a138-11e8-9345-8d51f8ed9678.jpg" alt="Goa">
            <div class="card-content">
                <h3>Goa Beach</h3>
                <p>Enjoy the sunny beaches and vibrant nightlife of Goa.</p>
                <a class="btn" href="https://www.google.com/maps?q=Goa+Beach" target="_blank">
                    Open in Google Maps
                </a>
            </div>
        </div>

        <!-- Location 2 -->
        <div class="card">
            <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcS0Stqay97vVR3rUwI9aabUm6L63yCSqf2Kkg&s" alt="Manali">
            <div class="card-content">
                <h3>Manali</h3>
                <p>Experience the snow-covered mountains and scenic beauty.</p>
                <a class="btn" href="https://www.google.com/maps?q=Manali" target="_blank">
                    Open in Google Maps
                </a>
            </div>
        </div>

        <!-- Location 3 -->
        <div class="card">
            <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSCLdweUUHPY7PKsSRg9ZJWr7V4EXly5Qe1TA&stgf">
            <div class="card-content">
                <h3>Bali</h3>
                <p>Where culture and nature coexists.</p>
                <a class="btn" href="https://www.google.com/maps?q=Bali+Indonesia" target="_blank">
                    Open in Google Maps
                </a>
            </div>
        </div>
 <!-- Location 4 -->
        <div class="card">
            <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRqilfR82wOM_E1bVI9r2ImcdxslA7S1LPXAA&s">
            <div class="card-content">
                <h3>Paris</h3>
                <p>Experience the magic of Paris with its iconic Eiffel Tower, charming streets, and world-class cuisine.</p>
                <a class="btn" href="https://www.google.com/maps?q=Paris+France" target="_blank">

                    Open in Google Maps
                </a>
            </div>
        </div>
<!-- Location 5 -->
        <div class="card">
            <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTUi-2e1H6A-K0m8o1m0QCwyBRrGe0SSwZ0Xw&s">
            <div class="card-content">
                <h3>Japan</h3>
                <p>From the neon lights of Tokyo to the peaceful temples of Kyoto, Japan offers unforgettable experiences.</p>
                <a class="btn" href="https://www.google.com/maps?q=Tokyo+Japan" target="_blank">

                    Open in Google Maps
                </a>
            </div>
        </div>


    </div>

    <footer>
        © 2026 My Travel Blog | Designed with ❤️
    </footer>

</body>
</html>
