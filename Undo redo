<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Undo Redo Text Editor</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f6f8;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .editor-container {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            width: 500px;
        }

        h2 {
            text-align: center;
        }

        textarea {
            width: 100%;
            height: 200px;
            padding: 10px;
            font-size: 16px;
            border-radius: 5px;
            border: 1px solid #ccc;
            resize: none;
            outline: none;
        }

        .buttons {
            margin-top: 10px;
            text-align: center;
        }

        button {
            padding: 10px 15px;
            margin: 5px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
        }

        .undo {
            background-color: #ff6b6b;
            color: white;
        }

        .redo {
            background-color: #4dabf7;
            color: white;
        }

        button:hover {
            opacity: 0.85;
        }
    </style>
</head>
<body>

<div class="editor-container">
    <h2>Undo / Redo Text Editor</h2>
    <textarea id="textInput" placeholder="Start typing..."></textarea>

    <div class="buttons">
        <button class="undo" onclick="undo()">Undo</button>
        <button class="redo" onclick="redo()">Redo</button>
    </div>
</div>

<script>
    let undoStack = [];
    let redoStack = [];

    const textInput = document.getElementById("textInput");

    // Save state on typing
    textInput.addEventListener("input", () => {
        undoStack.push(textInput.value);
        redoStack = []; // Clear redo stack
    });

    function undo() {
        if (undoStack.length > 1) {
            redoStack.push(undoStack.pop());
            textInput.value = undoStack[undoStack.length - 1];
        }
    }

    function redo() {
        if (redoStack.length > 0) {
            let value = redoStack.pop();
            undoStack.push(value);
            textInput.value = value;
        }
    }

    // Initialize with empty state
    undoStack.push("");
</script>

</body>
</html>
