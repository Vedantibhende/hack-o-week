<script>
let cart = JSON.parse(localStorage.getItem('cart')) || [];

function addToCart(button) {
  const menuItem = button.closest('.menu-item');
  const item = {
    id: Date.now() + Math.random(),
    name: menuItem.dataset.name,
    price: parseInt(menuItem.dataset.price),
    img: menuItem.dataset.img,
    desc: menuItem.dataset.desc,
    quantity: 1
  };

  // Check if item already exists in cart
  const existingItem = cart.find(cartItem => cartItem.name === item.name);
  if (existingItem) {
    existingItem.quantity += 1;
  } else {
    cart.push(item);
  }

  localStorage.setItem('cart', JSON.stringify(cart));
  updateCartCount();
  button.textContent = 'Added!';
  button.classList.add('added');
  
  setTimeout(() => {
    button.textContent = 'Add to Cart';
    button.classList.remove('added');
  }, 1500);
}

function updateCartCount() {
  const count = cart.reduce((total, item) => total + item.quantity, 0);
  document.getElementById('cartCount').textContent = count;
}

function updateCartDisplay() {
  const cartItemsEl = document.getElementById('cartItems');
  const totalPriceEl = document.getElementById('totalPrice');
  
  if (cart.length === 0) {
    cartItemsEl.innerHTML = '<div class="cart-empty">Your cart is empty</div>';
    totalPriceEl.textContent = '₹0';
    return;
  }

  cartItemsEl.innerHTML = cart.map(item => `
    <div class="cart-item">
      <img src="${item.img}" alt="${item.name}">
      <div class="cart-item-info">
        <div class="cart-item-name">${item.name}</div>
        <div class="cart-item-price">₹${item.price}</div>
        <div class="quantity-controls">
          <button class="qty-btn" onclick="updateQuantity('${item.id}', -1)">−</button>
          <span class="quantity">${item.quantity}</span>
          <button class="qty-btn" onclick="updateQuantity('${item.id}', 1)">+</button>
        </div>
      </div>
    </div>
  `).join('');

  const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
  totalPriceEl.textContent = ₹${total};
}

function updateQuantity(id, change) {
  cart = cart.map(item => {
    if (item.id === id) {
      item.quantity = Math.max(1, item.quantity + change);
      if (item.quantity === 0) {
        return null;
      }
    }
    return item;
  }).filter(Boolean);
  
  localStorage.setItem('cart', JSON.stringify(cart));
  updateCartCount();
  updateCartDisplay();
}

function checkout() {
  if (cart.length === 0) return;
  
  alert(Order Summary:\nTotal Items: ${cart.reduce((sum, item) => sum + item.quantity, 0)}\nTotal Amount: ₹${cart.reduce((sum, item) => sum + (item.price * item.quantity), 0)}\n\nThank you for your order!);
  cart = [];
  localStorage.removeItem('cart');
  updateCartCount();
  updateCartDisplay();
  document.getElementById('cartModal').classList.remove('active');
}

// Event listeners
document.getElementById('cartIcon').addEventListener('click', () => {
  document.getElementById('cartModal').classList.add('active');
  updateCartDisplay();
});

document.getElementById('closeCart').addEventListener('click', () => {
  document.getElementById('cartModal').classList.remove('active');
});

// Close modal when clicking outside
document.getElementById('cartModal').addEventListener('click', (e) => {
  if (e.target.id === 'cartModal') {
    document.getElementById('cartModal').classList.remove('active');
  }
});

// Initialize cart count on load
updateCartCount();
</script>

