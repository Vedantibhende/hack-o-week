<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Urban Bistro Menu</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  font-family:"Segoe UI",sans-serif;
  background:#0f0f0f;
  color:#f7f7f7;
}

/* HEADER */
header{
  background:#151515;
  padding:20px 40px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  position:sticky;
  top:0;
  z-index:100;
}

.logo{
  font-size:1.6rem;
  font-weight:bold;
  color:#ffb347;
}

nav{
  display: flex;
  align-items: center;
  gap: 20px;
}
nav a{
  color:#ddd;
  text-decoration:none;
}
nav a:hover{
  color:#ffb347;
}

/* CART ICON IN HEADER */
.cart-icon {
  background: linear-gradient(135deg, #ffb347, #ff8c00);
  color: #151515;
  width: 45px;
  height: 45px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.3rem;
  cursor: pointer;
  z-index: 1000;
  transition: all 0.3s ease;
  box-shadow: 0 4px 12px rgba(255,179,71,0.4);
  position: relative;
}
.cart-icon:hover {
  transform: scale(1.1) rotate(5deg);
  box-shadow: 0 6px 20px rgba(255,179,71,0.6);
}
.cart-count {
  position: absolute;
  top: -4px;
  right: -4px;
  background: #ff4444;
  color: white;
  border-radius: 50%;
  width: 18px;
  height: 18px;
  font-size: 0.75rem;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}

/* HERO */
.hero{
  background:url("https://images.unsplash.com/photo-1600891964599-f61ba0e24092?auto=format&fit=crop&w=1600&q=80")
  center/cover no-repeat;
  padding:110px 20px;
  text-align:center;
  position:relative;
}
.hero::before{
  content:"";
  position:absolute;
  inset:0;
  background:rgba(0,0,0,0.75);
}
.hero-content{
  position:relative;
  max-width:700px;
  margin:auto;
}
.hero h1{
  font-size:3rem;
  letter-spacing:3px;
}
.hero p{
  color:#ccc;
  margin-top:10px;
}

/* CATEGORY SLIDER */
.category-slider{
  text-align:center;
  margin:60px auto;
}
.category-slider h2{
  color:#ffb347;
  letter-spacing:2px;
  margin-bottom:25px;
}
.slider{
  display:flex;
  gap:25px;
  overflow-x:auto;
  padding:10px 20px;
}
.slider::-webkit-scrollbar{
  display:none;
}
.category-card{
  min-width:180px;
  background:#1a1a1a;
  border-radius:50%;
  padding:15px;
  cursor:pointer;
  transition:transform .3s;
}
.category-card:hover{
  transform:scale(1.08);
}
.category-card img{
  width:150px;
  height:150px;
  border-radius:50%;
  object-fit:cover;
}
.category-card p{
  margin-top:10px;
  font-size:.9rem;
}

/* MENU SECTIONS */
main{
  max-width:1200px;
  margin:auto;
  padding:40px 20px 80px;
}

.menu-section{
  margin-bottom:60px;
}
.menu-section h2{
  color:#ffb347;
  margin-bottom:10px;
  border-bottom:2px solid #333;
  display:inline-block;
}
.section-subtitle{
  color:#aaa;
  margin-bottom:30px;
}

.menu-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:25px;
}

.menu-item{
  background:#181818;
  border-radius:12px;
  overflow:hidden;
  transition:transform .3s;
  position: relative;
}
.menu-item:hover{
  transform:translateY(-6px);
}
.menu-item img{
  width:100%;
  height:190px;
  object-fit:cover;
}
.menu-content{
  padding:15px;
}
.menu-header{
  display:flex;
  justify-content:space-between;
  align-items: flex-start;
}
.menu-price{
  color:#ffb347;
  font-size: 1.1rem;
  font-weight: bold;
}
.menu-tag{
  font-size:.75rem;
  color:#999;
  margin:6px 0;
}
.menu-desc{
  font-size:.9rem;
  color:#ccc;
  margin-bottom: 12px;
}

/* ADD TO CART BUTTON */
.add-to-cart {
  width: 100%;
  background: linear-gradient(135deg, #ffb347, #ff8c00);
  color: #151515;
  border: none;
  padding: 10px 20px;
  border-radius: 25px;
  font-weight: bold;
  font-size: 0.9rem;
  cursor: pointer;
  transition: all 0.3s ease;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.add-to-cart:hover {
  background: linear-gradient(135deg, #ff8c00, #ffb347);
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(255,179,71,0.4);
}
.add-to-cart:active {
  transform: translateY(0);
}
.added {
  background: linear-gradient(135deg, #4CAF50, #45a049) !important;
}
.added:hover {
  background: linear-gradient(135deg, #45a049, #4CAF50) !important;
}

/* CART MODAL */
.cart-modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.9);
  z-index: 2000;
  backdrop-filter: blur(5px);
}
.cart-modal.active {
  display: flex;
  align-items: center;
  justify-content: center;
}
.cart-content {
  background: #1a1a1a;
  max-width: 500px;
  width: 90%;
  max-height: 80vh;
  border-radius: 15px;
  overflow-y: auto;
  position: relative;
  animation: slideIn 0.3s ease;
}
@keyframes slideIn {
  from { transform: translateY(-50px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
.cart-header {
  padding: 20px;
  border-bottom: 1px solid #333;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.close-cart {
  background: none;
  border: none;
  font-size: 1.8rem;
  color: #999;
  cursor: pointer;
}
.cart-items {
  padding: 20px;
  max-height: 400px;
  overflow-y: auto;
}
.cart-empty {
  text-align: center;
  color: #999;
  padding: 40px 20px;
}
.cart-item {
  display: flex;
  gap: 15px;
  padding: 15px 0;
  border-bottom: 1px solid #333;
}
.cart-item img {
  width: 60px;
  height: 60px;
  border-radius: 8px;
  object-fit: cover;
}
.cart-item-info {
  flex: 1;
}
.cart-item-name {
  font-weight: bold;
  margin-bottom: 5px;
}
.cart-item-price {
  color: #ffb347;
  font-weight: bold;
}
.quantity-controls {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 10px;
}
.qty-btn {
  background: #333;
  color: white;
  border: none;
  width: 30px;
  height: 30px;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}
.qty-btn:hover {
  background: #ffb347;
  color: #151515;
}
.quantity {
  font-weight: bold;
  min-width: 20px;
  text-align: center;
}
.cart-footer {
  padding: 20px;
  border-top: 1px solid #333;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.total-price {
  font-size: 1.3rem;
  font-weight: bold;
  color: #ffb347;
}
.checkout-btn {
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: white;
  border: none;
  padding: 12px 24px;
  border-radius: 25px;
  font-weight: bold;
  cursor: pointer;
  transition: all 0.3s ease;
}
.checkout-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(76,175,80,0.4);
}

/* ENHANCED FOOTER */
footer{
  background: #151515;
  padding: 40px 20px 20px;
  border-top: 2px solid #333;
  text-align: center;
}

.footer-content {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 30px;
  margin-bottom: 30px;
}

.footer-section h3 {
  color: #ffb347;
  margin-bottom: 15px;
  font-size: 1.2rem;
}

.footer-section p,
.footer-section a {
  color: #ccc;
  margin-bottom: 8px;
  text-decoration: none;
  display: block;
}

.footer-section a:hover {
  color: #ffb347;
}

.contact-info {
  background: #1a1a1a;
  padding: 20px;
  border-radius: 12px;
  border-left: 4px solid #ffb347;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.contact-icon {
  width: 35px;
  height: 35px;
  background: #ffb347;
  color: #151515;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  flex-shrink: 0;
}

.footer-bottom {
  border-top: 1px solid #333;
  padding-top: 20px;
  color: #777;
  font-size: 0.9rem;
}

@media (max-width: 768px) {
  .footer-content {
    grid-template-columns: 1fr;
    gap: 20px;
  }
  
  header {
    padding: 15px 20px;
  }
  
  nav {
    gap: 10px;
  }
}
</style>
</head>

